# Same Supabase keys as apps/web
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Live voice LLM (Groq)
GROQ_API_KEY=

# PDF form extraction (Gemini tier 1, Anthropic tier 2 fallback)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# RAG embeddings
COHERE_API_KEY=

# Optional Vapi assistant id for assistant-request webhook
VAPI_ASSISTANT_ID=

# Optional: defaults to 3001
PORT=3001

# Optional: error | warn | info | debug (defaults to info)
LOG_LEVEL=info

# Optional: pretty | json (defaults to pretty in dev, json in production)
LOG_FORMAT=pretty
